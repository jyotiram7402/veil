# --- Supabase (public, exposed to browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# --- Supabase service role (server only, NEVER expose) ---
# Settings -> API -> service_role key. Used by API routes to create users and
# bypass RLS where required. Keep this in Vercel encrypted env vars only.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# --- Internal email domain for the username<->auth.users mapping ---
# Supabase Auth requires an email per account. We synthesize one from the
# username so users never see or type an email. Use a domain you control
# (or any non-routable suffix). Do NOT change after seeding users.
INTERNAL_EMAIL_DOMAIN=rooms.local

# --- Admin bootstrap ---
# On first run, POST /api/admin/users with this header value to create users.
# Generate a strong random string (e.g. `openssl rand -hex 32`).
ADMIN_BOOTSTRAP_TOKEN=replace-me-with-a-long-random-string

# --- App URL (used for absolute links; optional locally) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
